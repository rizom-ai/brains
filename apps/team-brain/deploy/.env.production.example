# Secrets only — all config lives in brain.yaml
# Only values you'd rotate or revoke belong here.

# Required - AI API key
AI_API_KEY=your-api-key-here
# AI_IMAGE_KEY=your-image-key-here

# Optional - Matrix Interface (uncomment if using)

# Optional - MCP Interface Authentication
# Generate a secure token (minimum 32 characters recommended)
# MCP_AUTH_TOKEN=your-secure-token-here-minimum-32-chars

# Optional - Git Sync
# GIT_SYNC_TOKEN=ghp_YOUR_TOKEN_HERE

# Optional - Cloudflare
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
