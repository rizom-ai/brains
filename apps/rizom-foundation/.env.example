# rizom.foundation — Secrets Only
# All non-secret config lives in brain.yaml

# Required: AI API key (used by prompt entity materialization)
AI_API_KEY=your-api-key-here

# Optional: separate key for image generation (defaults to AI_API_KEY)
AI_IMAGE_KEY=

# Required when using directory-sync with the external content repo
GIT_SYNC_TOKEN=your-github-token

# Required: MCP interface authentication token (min 32 chars)
MCP_AUTH_TOKEN=your-mcp-token-minimum-32-chars
