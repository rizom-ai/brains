# Professional Brain Production Environment

# Domain configuration (required for HTTPS with Caddy)
DOMAIN=your-domain.com
# Preview environment (optional):
# PREVIEW_DOMAIN=preview.your-domain.com

# Required - AI API keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE
# OPENAI_API_KEY=sk-YOUR-KEY-HERE
# GOOGLE_GENERATIVE_AI_API_KEY=YOUR-KEY-HERE

# Required - Git sync (for content persistence)
GIT_SYNC_TOKEN=ghp_YOUR-GITHUB-TOKEN-HERE

# Required - LinkedIn publishing
LINKEDIN_ACCESS_TOKEN=YOUR-LINKEDIN-ACCESS-TOKEN-HERE

# Optional - Matrix bot (access token for matrix bot user)

# Optional - Discord bot
DISCORD_BOT_TOKEN=YOUR-DISCORD-BOT-TOKEN-HERE

# Optional - MCP Interface Authentication
# MCP_AUTH_TOKEN=your-secure-token-here-minimum-32-chars
