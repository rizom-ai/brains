# Professional Brain - Environment Variables
# Copy this file to .env and fill in your values

# AI Provider (Required)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# Optional AI providers (for image generation, etc.)
# OPENAI_API_KEY=sk-YOUR-KEY-HERE
# GOOGLE_GENERATIVE_AI_API_KEY=YOUR-KEY-HERE

# Git Sync
GIT_SYNC_TOKEN=github_pat_YOUR-TOKEN-HERE

# Matrix Chat Interface

# Discord Chat Interface
# DISCORD_BOT_TOKEN=your-discord-token

# MCP Authentication
# MCP_AUTH_TOKEN=your-secure-token-here

# LinkedIn (for social media publishing)
# LINKEDIN_ACCESS_TOKEN=your-linkedin-token

# Newsletter (Buttondown)
# BUTTONDOWN_API_KEY=your-buttondown-key

# Cloudflare Analytics
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token
# CLOUDFLARE_ANALYTICS_SITE_TAG=your-site-tag
