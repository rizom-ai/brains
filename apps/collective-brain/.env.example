# Rizom Collective Brain - Secrets Only
# All non-secret config lives in brain.yaml

# Required: AI API key
AI_API_KEY=your-api-key-here
# Optional: separate key for image generation
# AI_IMAGE_KEY=your-image-key-here

# Optional: MCP interface authentication token
MCP_AUTH_TOKEN=your-mcp-token

# Matrix bot access token

# Discord bot token
DISCORD_BOT_TOKEN=your-discord-bot-token

# Git sync token for brain-data repo
GIT_SYNC_TOKEN=ghp_...

# LinkedIn API (optional)
# LINKEDIN_ACCESS_TOKEN=your-linkedin-token
# LINKEDIN_ORGANIZATION_ID=your-org-id

# Cloudflare analytics (optional)
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token
# CLOUDFLARE_ANALYTICS_SITE_TAG=your-site-tag
