  },
  "devDependencies": {
    "@brains/eslint-config": "workspace:*",
    "@brains/test-utils": "workspace:*",
    "@brains/typescript-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "@types/node": "^20.19.43",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
