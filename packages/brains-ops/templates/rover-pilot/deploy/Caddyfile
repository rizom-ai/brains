# Internal Caddy — path-based routing to brain services.
# kamal-proxy terminates TLS externally; this runs inside the container.
:80 {
	@preview header_regexp preview_host Host ^(?:preview\..+|.+-preview\..+)$
	handle @preview {
		reverse_proxy localhost:4321

		header {
			X-Frame-Options "SAMEORIGIN"
			X-Content-Type-Options "nosniff"
			Referrer-Policy "strict-origin-when-cross-origin"
		}
	}

	# Health endpoint — canonical public /health lives on the shared webserver host
	handle /health {
		reverse_proxy localhost:8080
	}

	# MCP endpoint — routed through the shared webserver host
	handle /mcp* {
		reverse_proxy localhost:8080

		header {
			X-Content-Type-Options "nosniff"
			Access-Control-Allow-Origin "*"
			Access-Control-Allow-Methods "GET, POST, DELETE, OPTIONS"
			Access-Control-Allow-Headers "Content-Type, Authorization, MCP-Session-Id"
		}
	}

	# A2A endpoints — routed through the shared webserver host
	handle /.well-known/agent-card.json {
		reverse_proxy localhost:8080
	}

	handle /a2a {
		reverse_proxy localhost:8080

		header {
			X-Content-Type-Options "nosniff"
			Access-Control-Allow-Origin "*"
			Access-Control-Allow-Methods "GET, POST, OPTIONS"
			Access-Control-Allow-Headers "Content-Type, Authorization"
		}
	}

	# Plugin API routes
	handle /api/* {
		reverse_proxy localhost:3335
	}

	# Production site and shared HTTP surface
	handle {
		reverse_proxy localhost:8080

		header {
			X-Frame-Options "SAMEORIGIN"
			X-Content-Type-Options "nosniff"
			Referrer-Policy "strict-origin-when-cross-origin"
		}
	}
}
