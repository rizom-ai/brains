{
  "name": "@brains/build-tools",
  "private": true,
  "version": "0.2.0-alpha.136",
  "description": "Internal build and publish tooling: publishable-manifest transforms and declaration leak checks",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "publish-manifest": "./src/cli.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "bun test"
  },
  "devDependencies": {
    "@brains/eslint-config": "workspace:*",
    "@brains/typescript-config": "workspace:*",
    "@types/bun": "latest",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  }
}
