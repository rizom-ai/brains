{
  "name": "@brains/build-tools",
  "private": true,
  "version": "0.2.0-alpha.142",
  "description": "Internal build and publish tooling: publishable-manifest transforms and declaration leak checks",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "publish-manifest": "./src/cli.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "test": "bun test"
  },
  "devDependencies": {
    "@brains/eslint-config": "workspace:*",
    "@brains/typescript-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3"
  }
}
