{
  "$schema": "https://unpkg.com/syncpack@latest/dist/schema.json",
  "versionGroups": [
    {
      "label": "Public site packages pin concrete versions of published internal deps: npm publish builds the registry metadata from the on-disk manifest before prepack rewrites it, so workspace:* here ships broken packuments",
      "packages": [
        "@rizom/site",
        "@rizom/site-docs",
        "@rizom/site-rizom",
        "@rizom/site-rizom-ai",
        "@rizom/site-rizom-foundation",
        "@rizom/site-rizom-work",
        "@rizom/site-sections"
      ],
      "dependencies": [
        "@rizom/site",
        "@rizom/site-rizom",
        "@rizom/site-sections"
      ],
      "dependencyTypes": ["local", "prod"]
    },
    {
      "label": "Use workspace protocol for internal packages",
      "dependencies": ["@brains/**", "@rizom/**"],
      "dependencyTypes": ["dev", "prod"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "Pin Bun types",
      "dependencies": ["@types/bun", "bun-types"],
      "dependencyTypes": ["dev"],
      "policy": "sameRange"
    },
    {
      "label": "Sync TypeScript versions",
      "dependencies": ["typescript"],
      "dependencyTypes": ["dev"],
      "policy": "sameRange"
    },
    {
      "label": "Sync Zod versions",
      "dependencies": ["zod"],
      "dependencyTypes": ["dev", "prod"],
      "policy": "sameRange"
    },
    {
      "label": "Sync Preact versions",
      "dependencies": ["preact"],
      "dependencyTypes": ["dev", "prod"],
      "policy": "sameRange"
    }
  ],
  "semverGroups": [
    {
      "label": "Public site packages pin exact versions of published internal deps",
      "packages": [
        "@rizom/site-docs",
        "@rizom/site-rizom",
        "@rizom/site-rizom-ai",
        "@rizom/site-rizom-foundation",
        "@rizom/site-rizom-work",
        "@rizom/site-sections"
      ],
      "dependencies": [
        "@rizom/site",
        "@rizom/site-rizom",
        "@rizom/site-sections"
      ],
      "dependencyTypes": ["prod"],
      "range": ""
    },
    {
      "label": "Use caret ranges for all dependencies",
      "dependencies": ["**"],
      "dependencyTypes": ["dev", "prod", "peer"],
      "range": "^"
    }
  ],
  "sortFirst": [
    "name",
    "version",
    "description",
    "keywords",
    "license",
    "author"
  ],
  "sortAz": ["scripts", "dependencies", "devDependencies", "peerDependencies"]
}
