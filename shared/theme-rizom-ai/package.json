{
  "name": "@rizom/theme-rizom-ai",
  "version": "0.2.0-alpha.164",
  "description": "Consolidated rizom.ai theme — rev-5 design system: deep indigo ground, brass/ruby/moss room accents, warm off-white light mode, Fraunces + IBM Plex.",
  "license": "Apache-2.0",
  "author": "Yeehaa <yeehaa@rizom.ai> (https://rizom.ai)",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": "./src/types.d.ts"
  },
  "publishExports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun scripts/build.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "postpack": "publish-manifest restore",
    "prepack": "publish-manifest prepare",
    "prepublishOnly": "bun scripts/build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rizom/theme-default": "0.2.0-alpha.164"
  },
  "devDependencies": {
    "@brains/build-tools": "workspace:*",
    "@brains/eslint-config": "workspace:*",
    "@brains/typescript-config": "workspace:*",
    "eslint": "^10.5.0",
    "typescript": "^7.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rizom-ai/brains.git",
    "directory": "shared/theme-rizom-ai"
  },
  "homepage": "https://github.com/rizom-ai/brains/tree/main/shared/theme-rizom-ai#readme",
  "bugs": {
    "url": "https://github.com/rizom-ai/brains/issues"
  },
  "engines": {
    "bun": ">=1.3.3"
  }
}
