{
  "name": "@brains/utils",
  "version": "0.2.0-alpha.38",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./hash": {
      "types": "./src/hash.ts",
      "default": "./src/hash.ts"
    },
    "./origin-ca": {
      "types": "./src/origin-ca.ts",
      "default": "./src/origin-ca.ts"
    },
    "./deploy-scripts/*": {
      "types": "./src/deploy-scripts/*",
      "default": "./src/deploy-scripts/*"
    },
    "./deploy-templates": {
      "types": "./src/deploy-templates/index.ts",
      "default": "./src/deploy-templates/index.ts"
    },
    "./deploy-templates/*": {
      "types": "./src/deploy-templates/*.d.ts",
      "default": "./src/deploy-templates/*"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@brains/eslint-config": "workspace:*",
    "@brains/typescript-config": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "bun-types": "latest",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^12.0.0",
    "mdast-util-to-string": "^4.0.0",
    "nanoid": "^5.0.4",
    "p-limit": "^6.1.0",
    "remark": "^15.0.1",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.23.8"
  }
}
