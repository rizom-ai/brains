{
  "name": "@brains/deploy-support",
  "version": "0.2.0-alpha.141",
  "dependencies": {
    "@brains/utils": "workspace:*"
  },
  "devDependencies": {
    "@brains/eslint-config": "workspace:*",
    "@brains/typescript-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./deploy-scripts/*": {
      "types": "./src/deploy-scripts/*",
      "default": "./src/deploy-scripts/*"
    },
    "./origin-ca": {
      "types": "./src/origin-ca.ts",
      "default": "./src/origin-ca.ts"
    },
    "./push-target": {
      "types": "./src/push-target.ts",
      "default": "./src/push-target.ts"
    },
    "./push-secrets": {
      "types": "./src/push-secrets.ts",
      "default": "./src/push-secrets.ts"
    },
    "./run-subprocess": {
      "types": "./src/run-subprocess.ts",
      "default": "./src/run-subprocess.ts"
    },
    "./ssh-key-bootstrap": {
      "types": "./src/ssh-key-bootstrap.ts",
      "default": "./src/ssh-key-bootstrap.ts"
    }
  },
  "main": "./src/index.ts",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --max-warnings 0 --fix",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
