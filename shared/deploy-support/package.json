{
  "name": "@brains/deploy-support",
  "version": "0.2.0-alpha.137",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./deploy-scripts/*": {
      "types": "./src/deploy-scripts/*",
      "default": "./src/deploy-scripts/*"
    },
    "./origin-ca": {
      "types": "./src/origin-ca.ts",
      "default": "./src/origin-ca.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.ts\"",
    "lint:fix": "eslint \"**/*.ts\" --fix",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@brains/utils": "workspace:*"
  },
  "devDependencies": {
    "@brains/eslint-config": "workspace:*",
    "@brains/typescript-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
