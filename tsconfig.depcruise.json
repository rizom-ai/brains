{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Dependency-cruiser resolution config",
  // Resolution-only tsconfig for dependency-cruiser (see .dependency-cruiser.js).
  // Packages declare their own `@/*` aliases in their local tsconfigs, but
  // dependency-cruiser can only consume a single tsconfig for the whole cruise,
  // so the repo-wide `@/` conventions are mirrored here. Not used by tsc builds.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      // interfaces/web-chat maps `@/*` to its package root (ui-react imports).
      "@/ui-react/*": ["interfaces/web-chat/ui-react/*"],
      // shell/messaging-service maps `@/*` to its src/ (test imports).
      "@/*": ["shell/messaging-service/src/*"]
    }
  }
}
