{
  "name": "@brains/site-rizom",
  "version": "0.2.0-alpha.136",
  "description": "Shared Rizom site core — structural base for rizom.ai, rizom.foundation, and rizom.work",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun scripts/build.ts",
    "prepublishOnly": "bun scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun run build && bun test",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "preact": "^10.27.2",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@brains/atproto-contracts": "workspace:*",
    "@brains/eslint-config": "workspace:*",
    "@brains/site-composition": "workspace:*",
    "@brains/typescript-config": "workspace:*",
    "@rizom/ui": "workspace:*",
    "@types/bun": "latest",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rizom-ai/brains.git",
    "directory": "sites/rizom"
  },
  "license": "Apache-2.0",
  "author": "Yeehaa <yeehaa@rizom.ai> (https://rizom.ai)",
  "homepage": "https://github.com/rizom-ai/brains/tree/main/sites/rizom#readme",
  "bugs": {
    "url": "https://github.com/rizom-ai/brains/issues"
  },
  "engines": {
    "bun": ">=1.3.3"
  }
}
