{
  "lexicon": 1,
  "id": "ai.rizom.brain.card",
  "defs": {
    "main": {
      "type": "record",
      "description": "Public capability card for a Rizom brain.",
      "key": "literal:self",
      "record": {
        "type": "object",
        "required": ["name", "createdAt"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "maxLength": 2000
          },
          "brainDid": {
            "type": "string"
          },
          "anchorDid": {
            "type": "string"
          },
          "siteUrl": {
            "type": "string",
            "format": "uri"
          },
          "a2aEndpoint": {
            "type": "string",
            "format": "uri"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxLength": 100
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "updatedAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
