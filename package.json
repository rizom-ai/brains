{
  "name": "rizom-brains",
  "version": "0.0.0",
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/openai": "^3.0.71",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@manypkg/cli": "^0.25.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.206",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "lint-staged": "^17.0.7",
    "preact": "^10.27.2",
    "prettier": "^3.8.4",
    "syncpack": "^15.3.2",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "bun@1.0.0",
  "private": true,
  "overrides": {
    "zod": "^4.1.8"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "bun scripts/lint.mjs",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:unit": "turbo run test",
    "test:integration": "bun test test/integration",
    "test:all": "bun run test:unit && bun run test:integration",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "docs:links": "bun scripts/check-markdown-links.ts",
    "docs:manifest": "bun scripts/check-docs-manifest.ts",
    "roadmap:build": "bun scripts/build-roadmap-visual.ts",
    "roadmap:check": "bun scripts/build-roadmap-visual.ts --check",
    "docs:check": "bun run docs:links && bun run docs:manifest && bun run roadmap:check",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "clean:all": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "husky install",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "version:sync": "bun scripts/sync-versions.ts",
    "version:set": "bun scripts/sync-versions.ts && git add -A && git commit -m 'chore: sync package versions'",
    "deps:check": "syncpack lint",
    "deps:fix": "syncpack fix",
    "deps:format": "syncpack format",
    "deps:update": "syncpack update",
    "workspace:check": "manypkg check",
    "workspace:fix": "manypkg fix",
    "workspace:graph": "turbo run build --graph",
    "workspace:affected": "turbo run test --filter=[HEAD^1]",
    "arch:check": "depcruise --config .dependency-cruiser.js .",
    "arch:graph": "depcruise --config .dependency-cruiser.js --output-type dot . | dot -T svg > dependency-graph.svg"
  },
  "trustedDependencies": [],
  "workspaces": [
    "shell/*",
    "shared/*",
    "plugins/*",
    "entities/*",
    "interfaces/*",
    "brains/*",
    "sites/*",
    "packages/*",
    "apps/*"
  ]
}
