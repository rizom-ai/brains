{
  "name": "@brains/entity-service",
  "private": true,
  "version": "0.2.0-alpha.122",
  "description": "Entity service for managing brain entities with database persistence and serialization",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint \"**/*.ts\"",
    "lint:fix": "eslint \"**/*.ts\" --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/migrate.ts",
    "db:push": "drizzle-kit push:sqlite",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@brains/content-formatters": "workspace:*",
    "@brains/contracts": "workspace:*",
    "@brains/job-queue": "workspace:*",
    "@brains/utils": "workspace:*",
    "@libsql/client": "^0.17.4",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@brains/eslint-config": "workspace:*",
    "@brains/typescript-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./migrate": "./src/migrate.ts"
  },
  "files": [
    "src"
  ]
}
