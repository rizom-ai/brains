{
  "name": "@brains/ai-evaluation",
  "version": "0.2.0-alpha.141",
  "description": "AI evaluation system for testing agent and plugin performance",
  "bin": {
    "brain-eval": "./src/run-evaluations.ts"
  },
  "dependencies": {
    "@brains/ai-service": "workspace:*",
    "@brains/app": "workspace:*",
    "@brains/content-formatters": "workspace:*",
    "@brains/plugins": "workspace:*",
    "@brains/templates": "workspace:*",
    "@brains/utils": "workspace:*",
    "chalk": "^5.4.1",
    "dotenv": "^17.4.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@brains/eslint-config": "workspace:*",
    "@brains/typescript-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "main": "src/index.ts",
  "private": true,
  "scripts": {
    "eval": "cd evals && bun run brain-eval",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "types": "src/index.ts"
}
