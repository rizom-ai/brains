{
  "name": "@brains/app",
  "version": "0.2.0-alpha.142",
  "description": "High-level factory for creating Brain applications",
  "keywords": [
    "brain",
    "app",
    "factory"
  ],
  "license": "MIT",
  "author": "",
  "bin": {
    "brains": "./src/runner.ts",
    "brain-build": "./scripts/build.ts",
    "brain-migrate": "./scripts/migrate.ts",
    "brain-migrate-entities": "./scripts/migrate-entities.ts",
    "brain-migrate-job-queue": "./scripts/migrate-job-queue.ts",
    "brain-migrate-conversations": "./scripts/migrate-conversations.ts",
    "brain-migrate-runtime-state": "./scripts/migrate-runtime-state.ts"
  },
  "dependencies": {
    "@brains/core": "workspace:*",
    "@brains/plugins": "workspace:*",
    "@brains/runtime-state": "workspace:*",
    "@brains/site-composition": "workspace:*",
    "@brains/templates": "workspace:*",
    "@brains/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.19.43",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "varlock": "^1.7.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./contracts/brain-definition": "./src/contracts/brain-definition.ts"
  },
  "files": [
    "src",
    "scripts"
  ],
  "main": "src/index.ts",
  "private": true,
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "src/index.ts"
}
