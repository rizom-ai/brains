{
  "name": "@brains/conversation-service",
  "version": "0.2.0-alpha.143",
  "description": "Conversation storage and retrieval service for Brains",
  "dependencies": {
    "@brains/contracts": "workspace:*",
    "@brains/messaging-service": "workspace:*",
    "@brains/utils": "workspace:*",
    "@libsql/client": "^0.17.4",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.19.43",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./migrate": "./src/migrate.ts"
  },
  "main": "./src/index.ts",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "types": "./src/index.ts"
}
